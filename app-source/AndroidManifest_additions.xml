<!--
  ADD these permission lines to your project's AndroidManifest.xml.

  Location:  app/src/main/AndroidManifest.xml
  Paste them INSIDE <manifest ...> but ABOVE the <application ...> tag.
-->

<uses-permission android:name="android.permission.READ_CALL_LOG" />

<!-- Optional: lets the app show the contact NAME for known numbers so it can
     tell strangers apart from people you know. Safe to omit if you'd rather
     grant less. -->
<uses-permission android:name="android.permission.READ_CONTACTS" />

<!--
  On Android 9 and BELOW, writing the CSV needs this too. Harmless to include;
  ignored on Android 10+ where we use MediaStore.
-->
<uses-permission
    android:name="android.permission.WRITE_EXTERNAL_STORAGE"
    android:maxSdkVersion="28" />
